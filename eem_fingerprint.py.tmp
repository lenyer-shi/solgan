# -*- coding: utf-8 -*-
"""
水质三维荧光光谱（3D-EEM）指纹特征提取与比对工具
========================================================

参考文献:
  姜赞成 等. 基于三维荧光光谱的水体识别及组分快速解析算法研究.
  光学精密工程, 2025, 33(10): 1627-1637.

主要功能:
  1) 读取 CSV 格式的 EEM 数据 (第1行=发射波长, 第1列=激发波长, 末行=DARK 背景)
  2) 完整预处理流水线:
        a. DARK 背景扣减
        b. 16-bit 饱和值 (65535) 掩蔽
        c. 同 Ex 通道重复测量的稳健聚合 (中位数/Hampel) —— 抑制水质波动
        d. 空白扣减 (减去纯水 EEM)
        e. 瑞利/拉曼散射区域屏蔽 + Delaunay 三角形内插值
        f. 二维 Savitzky-Golay 平滑
  3) 指纹特征提取:
        a. 五区域荧光积分 FRI (Chen et al. 2003) —— 经典指纹
        b. 局部峰位检测 (Ex_peak, Em_peak, I_peak)
        c. 统计描述子 (总积分、均值、能量、加权矩心、标准差等)
        d. EEM 主体特征向量 (展平后用作 SAM/TCC/余弦比对)
  4) 指纹比对:
        a. 余弦相似度  Cosine
        b. Tucker 一致性系数  TCC
        c. 光谱角制图  SAM (Spectral Angle Mapper)
        d. Pearson 相关系数
        e. 归一化欧式距离
        f. FRI 五区相对比例的曼哈顿距离 (组成谱差异)

依赖:
  numpy, pandas   (可选 matplotlib 用于绘图; 缺失时自动跳过)
  —— 全部预处理算法均为纯 numpy 实现, 不依赖 scipy.

用法:
  python eem_fingerprint.py --blank blank.csv --sample industrial.csv \
        --outdir ./report  [--no-plot]

  或作为模块导入:
      from eem_fingerprint import EEMProcessor, compare_fingerprints
"""

from __future__ import annotations

import argparse
import json
import math
import os
import sys
import warnings
from dataclasses import dataclass, field, asdict
from typing import Dict, List, Optional, Tuple

import numpy as np
import pandas as pd

warnings.filterwarnings("ignore", category=RuntimeWarning)
warnings.filterwarnings("ignore", category=DeprecationWarning)

# numpy 1.x/2.x 兼容: trapezoid > trapz
_trapz = getattr(np, "trapezoid", np.trapz)


# =============================================================================
# 0. 纯 numpy 实现的 SG 平滑 / 最大值滤波 / 带状插值
# =============================================================================
def _sg_coeffs(window: int, poly: int, deriv: int = 0) -> np.ndarray:
    """Savitzky-Golay 滤波系数 (一维, 中心对称).

    通过求解 (A^T A)^-1 A^T 的对应行得到核, 与 scipy 实现等价.
    """
    if window % 2 == 0 or window < 1:
        raise ValueError("window 必须为奇正整数")
    if poly >= window:
        raise ValueError("poly 必须小于 window")
    half = window // 2
    x = np.arange(-half, half + 1, dtype=float)
    A = np.vstack([x ** k for k in range(poly + 1)]).T          # (window, poly+1)
    # 求伪逆: pinv(A) = (A^T A)^-1 A^T,  shape (poly+1, window)
    pinv = np.linalg.pinv(A)
    # 第 deriv 行即对应 deriv 阶导数滤波器系数 (再乘 deriv!)
    coeffs = pinv[deriv] * math.factorial(deriv)
    return coeffs


def _savgol_1d(arr: np.ndarray, window: int, poly: int,
               axis: int = -1) -> np.ndarray:
    """对一维方向做 SG 滤波, 边界用 'nearest' 复制."""
    if arr.shape[axis] < window:
        return arr
    coeffs = _sg_coeffs(window, poly)
    half = window // 2

    arr = np.moveaxis(arr, axis, -1)
    pad = [(0, 0)] * arr.ndim
    pad[-1] = (half, half)
    padded = np.pad(arr, pad, mode="edge")

    # 卷积: 结果长度 == arr.shape[-1]
    out = np.zeros_like(arr)
    for k, c in enumerate(coeffs):
        out += c * padded[..., k:k + arr.shape[-1]]
    return np.moveaxis(out, -1, axis)


def _local_maxima_2d(M: np.ndarray, neighborhood=5) -> np.ndarray:
    """
    返回与 M 同形的布尔数组, True 表示 (i,j) 是 neighborhood 邻域内的极大值.
    neighborhood 可以是 int (方形) 或 (h_ex, h_em) 二元组.
    """
    h, w = M.shape
    if isinstance(neighborhood, (tuple, list)):
        half_i, half_j = int(neighborhood[0]) // 2, int(neighborhood[1]) // 2
    else:
        half_i = half_j = int(neighborhood) // 2
    half_i = max(0, min(half_i, h - 1))
    half_j = max(0, min(half_j, w - 1))
    is_max = np.ones_like(M, dtype=bool)
    for di in range(-half_i, half_i + 1):
        for dj in range(-half_j, half_j + 1):
            if di == 0 and dj == 0:
                continue
            i0_src, i1_src = max(0, di), min(h, h + di)
            j0_src, j1_src = max(0, dj), min(w, w + dj)
            i0_dst, i1_dst = max(0, -di), min(h, h - di)
            j0_dst, j1_dst = max(0, -dj), min(w, w - dj)
            if i1_src <= i0_src or j1_src <= j0_src:
                continue
            shifted = np.full_like(M, -np.inf)
            shifted[i0_dst:i1_dst, j0_dst:j1_dst] = \
                M[i0_src:i1_src, j0_src:j1_src]
            is_max &= (M >= shifted)
    return is_max


def _interp_band(em: np.ndarray, row: np.ndarray) -> np.ndarray:
    """对一行光谱中 NaN 位置用相邻有效点 1D 线性插值 (端点用最近值复制)."""
    valid = ~np.isnan(row)
    if valid.sum() == 0:
        return np.zeros_like(row)
    if valid.all():
        return row
    out = row.copy()
    out[~valid] = np.interp(em[~valid], em[valid], row[valid])
    return out

# 可选绘图依赖
try:
    import matplotlib
    matplotlib.use("Agg")
    import matplotlib.pyplot as plt
    _HAS_MPL = True
except Exception:
    _HAS_MPL = False


# =============================================================================
# 1. 数据结构
# =============================================================================
@dataclass
class EEM:
    """三维激发-发射矩阵的标准化容器 (聚合后)。"""
    ex: np.ndarray            # shape: (n_ex,)  激发波长 (升序、去重)
    em: np.ndarray            # shape: (n_em,)  发射波长
    intensity: np.ndarray     # shape: (n_ex, n_em)  荧光强度矩阵


@dataclass
class Fingerprint:
    """从 EEM 中提取的指纹特征。"""
    fri_volumes: Dict[str, float]            # 五区积分体积 (绝对值)
    fri_fractions: Dict[str, float]          # 五区相对占比 (∑=1)
    peaks: List[Dict[str, float]]            # 主峰列表 [{ex, em, intensity}, ...]
    stats: Dict[str, float]                  # 总能量、均值、矩心等
    feature_vector: np.ndarray               # 标准化的展平特征向量 (用于 SAM/TCC)
    ex: np.ndarray = field(repr=False)
    em: np.ndarray = field(repr=False)
    matrix: np.ndarray = field(repr=False)   # 预处理后的 EEM (用于绘图/调试)

    def to_serializable(self) -> dict:
        return {
            "fri_volumes": self.fri_volumes,
            "fri_fractions": self.fri_fractions,
            "peaks": self.peaks,
            "stats": self.stats,
        }


# =============================================================================
# 2. CSV 读取
# =============================================================================
def read_eem_csv(path: str) -> Tuple[np.ndarray, List[str], np.ndarray]:
    """
    读取约定格式的 EEM CSV.

    返回:
        em (np.ndarray)            : (n_em,)  发射波长
        ex_labels (List[str])      : 长度 n_rows 的激发波长标签 (含 'DARK')
        intensity (np.ndarray)     : (n_rows, n_em)  原始计数 (含 DARK 行)
    """
    # encoding 用 utf-8-sig 自动剥离 BOM
    df = pd.read_csv(path, encoding="utf-8-sig")
    em = df.columns[1:].astype(float).to_numpy()
    ex_labels = df.iloc[:, 0].astype(str).str.strip().tolist()
    intensity = df.iloc[:, 1:].astype(float).to_numpy()
    return em, ex_labels, intensity


# =============================================================================
# 3. 预处理流水线
# =============================================================================
SATURATION_VALUE = 65535  # 16-bit ADC 上限


def _split_dark(ex_labels: List[str], data: np.ndarray
                ) -> Tuple[np.ndarray, List[float], np.ndarray]:
    """分离 DARK 行与通道行。"""
    dark_idx = [i for i, lab in enumerate(ex_labels) if lab.upper() == "DARK"]
    chan_idx = [i for i in range(len(ex_labels)) if i not in dark_idx]
    if not dark_idx:
        raise ValueError("未找到 DARK 行,无法进行背景扣减.")
    dark = data[dark_idx[0]]                                  # (n_em,)
    channel_data = data[chan_idx]                             # (n_chan, n_em)
    channel_ex = [float(ex_labels[i]) for i in chan_idx]
    return dark, channel_ex, channel_data


def _aggregate_duplicate_ex(channel_ex: List[float],
                            channel_data: np.ndarray,
                            method: str = "median"
                            ) -> Tuple[np.ndarray, np.ndarray]:
    """
    将相同 Ex 的多个通道聚合为单条行,以抑制水质波动带来的波动.

    method:
        'median'  - 中位数 (默认, 对偶发尖峰最稳健)
        'hampel'  - 中位数 + MAD 离群剔除后再均值
        'mean'    - 简单算术平均 (噪声最低但易被离群拉偏)
        'tmean'   - 25% 截尾均值
    """
    ex_arr = np.array(channel_ex, dtype=float)
    unique_ex = np.unique(ex_arr)
    aggregated = np.zeros((len(unique_ex), channel_data.shape[1]),
                          dtype=float)

    for k, ex_val in enumerate(unique_ex):
        rows = channel_data[ex_arr == ex_val]                  # (m, n_em)
        if rows.shape[0] == 1:
            aggregated[k] = rows[0]
            continue

        if method == "mean":
            aggregated[k] = np.nanmean(rows, axis=0)
        elif method == "tmean":
            # 25% 截尾均值: 排序后去掉首尾 25%
            sorted_ = np.sort(rows, axis=0)
            m = sorted_.shape[0]
            lo = int(np.floor(m * 0.25))
            hi = m - lo if m - lo > lo else m
            aggregated[k] = np.nanmean(sorted_[lo:hi], axis=0)
        elif method == "hampel":
            med = np.nanmedian(rows, axis=0)
            mad = np.nanmedian(np.abs(rows - med), axis=0) * 1.4826
            mad[mad == 0] = 1e-9
            mask = np.abs(rows - med) <= 3 * mad
            tmp = np.where(mask, rows, np.nan)
            agg = np.nanmean(tmp, axis=0)
            # 若全部被剔除则回落到中位数
            agg = np.where(np.isnan(agg), med, agg)
            aggregated[k] = agg
        else:                       # 默认 median
            aggregated[k] = np.nanmedian(rows, axis=0)

    return unique_ex, aggregated


def _mask_scatter(ex: np.ndarray, em: np.ndarray, M: np.ndarray,
                  rayleigh_band: float = 15.0,
                  raman_band: float = 15.0
                  ) -> np.ndarray:
    """
    将瑞利散射 (1阶/2阶) 和水的拉曼散射区域置 NaN.
    一阶 Rayleigh : Em ≈ Ex
    二阶 Rayleigh : Em ≈ 2*Ex
    水的 Raman   : 1/Em = 1/Ex - 3.4e-4 (单位 nm)
    """
    out = M.astype(float).copy()
    EX, EM = np.meshgrid(ex, em, indexing="ij")            # (n_ex, n_em)

    rayleigh1 = np.abs(EM - EX) < rayleigh_band
    rayleigh2 = np.abs(EM - 2 * EX) < rayleigh_band

    # Raman 位移 (水 ~3400 cm^-1) = 1 / (1/Ex - 0.00034)
    em_raman = 1.0 / (1.0 / EX - 3.4e-4)
    raman = np.abs(EM - em_raman) < raman_band

    # Em < Ex 的区域属于反斯托克斯, 一般也无意义
    below = EM < EX - rayleigh_band

    out[rayleigh1 | rayleigh2 | raman | below] = np.nan
    return out


def _interpolate_nan(ex: np.ndarray, em: np.ndarray, M: np.ndarray
                     ) -> np.ndarray:
    """
    对 NaN 区域插值补全.

    瑞利/拉曼散射在 EEM 上呈现为沿 Em 方向的 *斜带*. 由于 Ex 通道数远少于 Em,
    最稳健的做法是: 先沿 Em 方向逐行 1D 线性插值 (类似 Delaunay 在窄带内的退化形式),
    再沿 Ex 方向对仍残留的 NaN 列做 1D 插值. 该方案在数据稀疏的 Ex 维度上比
    完整 Delaunay 更稳定, 也是 drEEM 等工具的常用替代实现.
    """
    if not np.any(np.isnan(M)):
        return M
    out = np.array([_interp_band(em, row) for row in M])

    # Ex 方向: 若仍有列全 NaN, 再插一次
    nan_cols = np.where(np.any(np.isnan(out), axis=0))[0]
    for j in nan_cols:
        col = out[:, j]
        valid = ~np.isnan(col)
        if valid.any():
            out[~valid, j] = np.interp(ex[~valid], ex[valid], col[valid])
        else:
            out[:, j] = 0.0
    return out


def _sg_smooth_2d(M: np.ndarray, window: int = 11, poly: int = 3
                  ) -> np.ndarray:
    """二维 Savitzky-Golay: 先沿 Em 方向, 再沿 Ex 方向 (两次 1D 是2D SG 的常用扩展)."""
    if M.shape[1] >= window:
        M = _savgol_1d(M, window=window, poly=poly, axis=1)
    if M.shape[0] >= 3:                              # Ex 方向通常很短, 用更小窗
        n_ex = M.shape[0]
        w_ex = window if window <= n_ex else (n_ex if n_ex % 2 == 1 else n_ex - 1)
        if w_ex >= 3 and w_ex > poly:
            M = _savgol_1d(M, window=w_ex,
                           poly=min(poly, w_ex - 1), axis=0)
    return M


# 主类 ---------------------------------------------------------------------
class EEMProcessor:
    """
    三维荧光光谱处理器.

    参数:
        rayleigh_band : 瑞利散射屏蔽带宽 (nm)
        raman_band    : 拉曼散射屏蔽带宽 (nm)
        sg_window     : SG 平滑窗口 (奇数)
        sg_poly       : SG 多项式阶
        agg_method    : 同 Ex 通道聚合方法
        em_range      : (em_min, em_max) 截取的发射波长范围, None 则保持原始
        ex_keep_below : 当激发波长大于此值时丢弃 (默认 600, 排除 660/700 长波激发对有机指纹意义不大)
    """

    def __init__(self,
                 rayleigh_band: float = 15.0,
                 raman_band: float = 15.0,
                 sg_window: int = 11,
                 sg_poly: int = 3,
                 agg_method: str = "median",
                 em_range: Optional[Tuple[float, float]] = (250.0, 600.0),
                 ex_keep_below: float = 600.0):
        self.rayleigh_band = rayleigh_band
        self.raman_band = raman_band
        self.sg_window = sg_window
        self.sg_poly = sg_poly
        self.agg_method = agg_method
        self.em_range = em_range
        self.ex_keep_below = ex_keep_below

    # ---- 单文件处理 ------------------------------------------------------
    def load_and_aggregate(self, path: str) -> EEM:
        """读取 CSV → DARK 扣减 → 饱和掩蔽 → 同 Ex 聚合 → 区间裁剪."""
        em, ex_labels, raw = read_eem_csv(path)

        # 1) 标记饱和点 (转 NaN)
        raw = raw.astype(float)
        raw[raw >= SATURATION_VALUE] = np.nan

        # 2) 拆分 DARK
        dark, ex_list, channels = _split_dark(ex_labels, raw)

        # 3) DARK 扣减 (DARK 不含饱和数,保险起见)
        dark = np.where(np.isnan(dark), 0.0, dark)
        channels = channels - dark[None, :]

        # 4) 同 Ex 通道稳健聚合 → 抑制水质波动
        unique_ex, agg = _aggregate_duplicate_ex(ex_list, channels,
                                                 method=self.agg_method)

        # 5) 丢弃过长 Ex (660, 700 等)
        keep = unique_ex < self.ex_keep_below
        unique_ex = unique_ex[keep]
        agg = agg[keep]

        # 6) Em 区间裁剪 (减少散射区域和无信号区)
        if self.em_range is not None:
            lo, hi = self.em_range
            mask_em = (em >= lo) & (em <= hi)
            em = em[mask_em]
            agg = agg[:, mask_em]

        # 把 DARK 残留的负值置 0
        agg = np.where(np.isnan(agg), np.nan, agg)
        return EEM(ex=unique_ex, em=em, intensity=agg)

    # ---- 空白扣减 + 散射处理 + 平滑 -------------------------------------
    def correct(self, sample: EEM, blank: EEM) -> EEM:
        """空白扣减 → 散射屏蔽+插值 → SG 平滑 → 截断负值."""
        if sample.ex.shape != blank.ex.shape or \
           not np.allclose(sample.ex, blank.ex):
            raise ValueError("sample 与 blank 的 Ex 通道不一致, 请确保设备配置相同.")
        if sample.em.shape != blank.em.shape or \
           not np.allclose(sample.em, blank.em):
            # 用插值对齐 Em
            blank_aligned = np.array([
                np.interp(sample.em, blank.em, row) for row in blank.intensity
            ])
        else:
            blank_aligned = blank.intensity

        # 1) 空白扣减
        diff = np.where(np.isnan(sample.intensity), np.nan,
                        sample.intensity - np.nan_to_num(blank_aligned))

        # 2) 散射屏蔽
        masked = _mask_scatter(sample.ex, sample.em, diff,
                               rayleigh_band=self.rayleigh_band,
                               raman_band=self.raman_band)

        # 3) Delaunay 内插补全
        filled = _interpolate_nan(sample.ex, sample.em, masked)

        # 4) SG 平滑
        smoothed = _sg_smooth_2d(filled, self.sg_window, self.sg_poly)

        # 5) 负值截断 (空白扣减后水质指纹必须 ≥ 0)
        smoothed = np.clip(smoothed, 0.0, None)

        return EEM(ex=sample.ex.copy(), em=sample.em.copy(),
                   intensity=smoothed)


# =============================================================================
# 4. 指纹特征提取
# =============================================================================
# Chen et al. 2003 的 FRI 五区域定义 (经典)
FRI_REGIONS: Dict[str, Tuple[Tuple[float, float], Tuple[float, float]]] = {
    # name : ((ex_lo, ex_hi), (em_lo, em_hi))
    "I_Tyrosine":      ((220.0, 250.0), (250.0, 330.0)),    # 类酪氨酸 (芳香蛋白 I)
    "II_Tryptophan":   ((220.0, 250.0), (330.0, 380.0)),    # 类色氨酸 (芳香蛋白 II)
    "III_FulvicAcid":  ((220.0, 250.0), (380.0, 500.0)),    # 类富里酸
    "IV_SMP":          ((250.0, 340.0), (250.0, 380.0)),    # 溶解性微生物代谢产物
    "V_HumicAcid":     ((250.0, 400.0), (380.0, 600.0)),    # 类腐殖酸
}


def _region_volume(eem: EEM, ex_lim: Tuple[float, float],
                   em_lim: Tuple[float, float]) -> float:
    """对指定 (Ex, Em) 矩形区域用 trapz 积分得到荧光体积."""
    ex_mask = (eem.ex >= ex_lim[0]) & (eem.ex <= ex_lim[1])
    em_mask = (eem.em >= em_lim[0]) & (eem.em <= em_lim[1])
    if ex_mask.sum() == 0 or em_mask.sum() == 0:
        return 0.0
    sub = eem.intensity[np.ix_(ex_mask, em_mask)]
    sub = np.nan_to_num(sub, nan=0.0)
    if sub.shape[0] < 2 or sub.shape[1] < 2:
        return float(np.nansum(sub))
    vol = _trapz(_trapz(sub, eem.em[em_mask], axis=1),
                   eem.ex[ex_mask])
    return float(vol)


def _detect_peaks(eem: EEM, top_n: int = 5,
                  neighborhood=(3, 41),
                  min_prominence_ratio: float = 0.15,
                  min_em_separation: float = 15.0,
                  min_ex_separation: float = 10.0,
                  ) -> List[Dict[str, float]]:
    """
    用局部极大值滤波器检测主荧光峰, 并对相邻峰做距离去重.
    neighborhood 沿 Em 方向较大 (Em 网格密集), 默认 41 ≈ 12 nm.
    返回最多 top_n 个峰, 按强度降序.
    """
    M = np.nan_to_num(eem.intensity, nan=0.0)
    if M.size == 0 or M.max() <= 0:
        return []
    local_max = _local_maxima_2d(M, neighborhood=neighborhood)
    threshold = M.max() * min_prominence_ratio
    peak_mask = local_max & (M >= threshold)
    coords = np.argwhere(peak_mask)
    raw_peaks = sorted(
        ({"ex": float(eem.ex[i]),
          "em": float(eem.em[j]),
          "intensity": float(M[i, j])}
         for i, j in coords),
        key=lambda d: d["intensity"], reverse=True
    )
    # 距离去重: 若新峰与已收录的某个峰在 (Ex, Em) 上都很近, 则跳过
    kept: List[Dict[str, float]] = []
    for pk in raw_peaks:
        if any(abs(pk["ex"] - q["ex"]) < min_ex_separation and
               abs(pk["em"] - q["em"]) < min_em_separation for q in kept):
            continue
        kept.append(pk)
        if len(kept) >= top_n:
            break
    return kept


def _statistics(eem: EEM) -> Dict[str, float]:
    """光谱整体统计量."""
    M = np.nan_to_num(eem.intensity, nan=0.0)
    if M.size == 0:
        return {}

    total = float(_trapz(_trapz(M, eem.em, axis=1), eem.ex))
    mean_int = float(np.mean(M))
    energy = float(np.sum(M ** 2))

    # 加权矩心 (强度作为权重)
    w = M / (M.sum() + 1e-12)
    EX, EM = np.meshgrid(eem.ex, eem.em, indexing="ij")
    cx = float((w * EX).sum())
    cy = float((w * EM).sum())
    sx = float(np.sqrt(((w * (EX - cx) ** 2)).sum()))
    sy = float(np.sqrt(((w * (EM - cy) ** 2)).sum()))

    return {
        "total_volume": total,
        "mean_intensity": mean_int,
        "energy": energy,
        "centroid_ex_nm": cx,
        "centroid_em_nm": cy,
        "spread_ex_nm": sx,
        "spread_em_nm": sy,
        "max_intensity": float(M.max()),
    }


def extract_fingerprint(eem: EEM,
                        top_peaks: int = 5) -> Fingerprint:
    """从已预处理的 EEM 中抽取指纹特征."""
    # 五区域 FRI 体积 + 占比
    volumes = {name: _region_volume(eem, ex_lim, em_lim)
               for name, (ex_lim, em_lim) in FRI_REGIONS.items()}
    total = sum(volumes.values()) or 1e-12
    fractions = {k: v / total for k, v in volumes.items()}

    peaks = _detect_peaks(eem, top_n=top_peaks)
    stats = _statistics(eem)

    # 标准化展平特征向量 (用于 SAM/TCC/cosine)
    M = np.nan_to_num(eem.intensity, nan=0.0).ravel()
    norm = np.linalg.norm(M)
    fv = M / norm if norm > 0 else M

    return Fingerprint(
        fri_volumes=volumes,
        fri_fractions=fractions,
        peaks=peaks,
        stats=stats,
        feature_vector=fv,
        ex=eem.ex, em=eem.em, matrix=eem.intensity,
    )


# =============================================================================
# 5. 指纹比对
# =============================================================================
def cosine_similarity(a: np.ndarray, b: np.ndarray) -> float:
    na, nb = np.linalg.norm(a), np.linalg.norm(b)
    if na == 0 or nb == 0:
        return 0.0
    return float(np.dot(a, b) / (na * nb))


def tucker_congruence(a: np.ndarray, b: np.ndarray) -> float:
    """Tucker 一致性系数, 与余弦相似度数学等价但被 PARAFAC 社区广泛使用."""
    return cosine_similarity(a, b)


def spectral_angle(a: np.ndarray, b: np.ndarray) -> float:
    """SAM, 单位 度 (越小越相似)."""
    cs = max(min(cosine_similarity(a, b), 1.0), -1.0)
    return float(np.degrees(np.arccos(cs)))


def pearson_correlation(a: np.ndarray, b: np.ndarray) -> float:
    a, b = a - a.mean(), b - b.mean()
    na, nb = np.linalg.norm(a), np.linalg.norm(b)
    if na == 0 or nb == 0:
        return 0.0
    return float(np.dot(a, b) / (na * nb))


def euclidean_distance_norm(a: np.ndarray, b: np.ndarray) -> float:
    """归一化欧式距离 (向量先各自单位化)."""
    na, nb = np.linalg.norm(a), np.linalg.norm(b)
    if na == 0 or nb == 0:
        return float("inf")
    return float(np.linalg.norm(a / na - b / nb))


def fri_composition_distance(f1: Fingerprint, f2: Fingerprint) -> float:
    """FRI 五区组成的曼哈顿距离 (∈[0, 2], 0=组成相同)."""
    keys = list(FRI_REGIONS.keys())
    v1 = np.array([f1.fri_fractions[k] for k in keys])
    v2 = np.array([f2.fri_fractions[k] for k in keys])
    return float(np.sum(np.abs(v1 - v2)))


def compare_fingerprints(f1: Fingerprint, f2: Fingerprint) -> Dict[str, float]:
    """综合比对两个指纹, 返回常用相似度/距离指标."""
    a, b = f1.feature_vector, f2.feature_vector
    return {
        "cosine_similarity": cosine_similarity(a, b),
        "tucker_congruence": tucker_congruence(a, b),
        "spectral_angle_deg": spectral_angle(a, b),
        "pearson_correlation": pearson_correlation(a, b),
        "euclidean_distance": euclidean_distance_norm(a, b),
        "fri_composition_l1": fri_composition_distance(f1, f2),
    }


def overall_match_score(metrics: Dict[str, float]) -> float:
    """
    将多种指标加权综合为 0~1 的总相似度评分:
        cosine 越大越相似, SAM 越小越相似, fri_l1 越小越相似.
    """
    cos = metrics["cosine_similarity"]
    sam_s = 1.0 - metrics["spectral_angle_deg"] / 90.0
    fri_s = 1.0 - 0.5 * metrics["fri_composition_l1"]
    pearson = (metrics["pearson_correlation"] + 1.0) / 2.0
    score = 0.4 * max(cos, 0) + 0.2 * max(sam_s, 0) + \
            0.2 * max(fri_s, 0) + 0.2 * max(pearson, 0)
    return float(np.clip(score, 0.0, 1.0))


# =============================================================================
# 6. 报告与可视化
# =============================================================================
def _human_table(d: dict, fmt: str = "{:.4f}") -> str:
    width = max(len(k) for k in d) + 2
    return "\n".join(f"  {k.ljust(width)} {fmt.format(v) if isinstance(v, (int, float)) else v}"
                     for k, v in d.items())


def write_text_report(blank_path: str, sample_path: str,
                      fp_blank: Fingerprint, fp_sample: Fingerprint,
                      metrics: Dict[str, float], out_path: str) -> None:
    score = overall_match_score(metrics)
    lines = [
        "=" * 70,
        "  水质三维荧光光谱指纹比对报告",
        "=" * 70,
        f"空白文件 : {blank_path}",
        f"样本文件 : {sample_path}",
        "",
        "[1] 样本 EEM 整体统计",
        _human_table(fp_sample.stats),
        "",
        "[2] 五区域荧光积分体积 (FRI, 经典 Chen 2003)",
        _human_table(fp_sample.fri_volumes, fmt="{:.3e}"),
        "",
        "[3] 五区域相对占比",
        _human_table(fp_sample.fri_fractions, fmt="{:.4f}"),
        "",
        "[4] 主荧光峰 (Top-{n})".format(n=len(fp_sample.peaks)),
    ]
    for i, pk in enumerate(fp_sample.peaks, 1):
        lines.append(f"  Peak{i}: Ex={pk['ex']:.1f} nm, "
                     f"Em={pk['em']:.1f} nm, I={pk['intensity']:.3e}")
    lines += [
        "",
        "[5] 与空白 (纯水) 的指纹比对指标",
        _human_table(metrics),
        "",
        f">>> 综合相似度评分 : {score:.4f}  (1=完全一致, 0=完全不同)",
        "    评分含义: 越接近 0 表示样本 EEM 与纯水基线差异越大,",
        "             即水质中含有更多有机荧光组分.",
        "=" * 70,
    ]
    with open(out_path, "w", encoding="utf-8") as f:
        f.write("\n".join(lines))


def plot_eem(eem: EEM, title: str, path: str) -> None:
    if not _HAS_MPL:
        return
    fig, ax = plt.subplots(figsize=(7, 5))
    M = np.nan_to_num(eem.intensity, nan=0.0)
    cs = ax.contourf(eem.em, eem.ex, M, levels=24, cmap="jet")
    ax.set_xlabel("Emission wavelength / nm")
    ax.set_ylabel("Excitation wavelength / nm")
    ax.set_title(title)
    fig.colorbar(cs, ax=ax, label="Intensity (a.u.)")
    fig.tight_layout()
    fig.savefig(path, dpi=130)
    plt.close(fig)


def plot_fri_bar(fp: Fingerprint, path: str) -> None:
    if not _HAS_MPL:
        return
    fig, ax = plt.subplots(figsize=(7, 4))
    keys = list(fp.fri_fractions.keys())
    vals = [fp.fri_fractions[k] for k in keys]
    ax.bar(keys, vals, color=["#4C72B0", "#55A868", "#C44E52",
                              "#8172B2", "#CCB974"])
    ax.set_ylabel("Fraction")
    ax.set_title("FRI 5-region composition")
    plt.xticks(rotation=20, ha="right")
    fig.tight_layout()
    fig.savefig(path, dpi=130)
    plt.close(fig)


# =============================================================================
# 7. CLI 入口
# =============================================================================
def main(argv: Optional[List[str]] = None) -> int:
    parser = argparse.ArgumentParser(
        description="水质三维荧光光谱指纹特征提取与比对工具")
    parser.add_argument("--blank", required=True,
                        help="纯水 EEM CSV 文件 (空白)")
    parser.add_argument("--sample", required=True,
                        help="待测样本 EEM CSV 文件")
    parser.add_argument("--outdir", default="./eem_report",
                        help="输出目录, 默认 ./eem_report")
    parser.add_argument("--agg", default="median",
                        choices=["median", "hampel", "mean", "tmean"],
                        help="同 Ex 通道聚合方法, 抑制水质波动")
    parser.add_argument("--em-min", type=float, default=250.0)
    parser.add_argument("--em-max", type=float, default=600.0)
    parser.add_argument("--no-plot", action="store_true",
                        help="不生成图像")
    args = parser.parse_args(argv)

    os.makedirs(args.outdir, exist_ok=True)

    proc = EEMProcessor(agg_method=args.agg,
                        em_range=(args.em_min, args.em_max))

    print("[1/4] 读取并聚合空白...")
    blank_raw = proc.load_and_aggregate(args.blank)
    print(f"     blank: ex={blank_raw.ex.tolist()}, "
          f"em in [{blank_raw.em[0]:.1f},{blank_raw.em[-1]:.1f}], "
          f"shape={blank_raw.intensity.shape}")

    print("[2/4] 读取并聚合样本...")
    sample_raw = proc.load_and_aggregate(args.sample)

    print("[3/4] 空白扣减 + 散射屏蔽 + SG 平滑...")
    sample_corr = proc.correct(sample_raw, blank_raw)
    blank_zero = EEM(ex=blank_raw.ex, em=blank_raw.em,
                     intensity=np.zeros_like(blank_raw.intensity))
    blank_corr = proc.correct(blank_raw, blank_zero)

    print("[4/4] 提取指纹并进行比对...")
    fp_sample = extract_fingerprint(sample_corr)
    fp_blank = extract_fingerprint(blank_corr)
    metrics = compare_fingerprints(fp_blank, fp_sample)
    score = overall_match_score(metrics)

    txt_report = os.path.join(args.outdir, "report.txt")
    write_text_report(args.blank, args.sample,
                      fp_blank, fp_sample, metrics, txt_report)

    json_report = os.path.join(args.outdir, "fingerprint.json")
    with open(json_report, "w", encoding="utf-8") as f:
        json.dump({
            "blank_file": os.path.abspath(args.blank),
            "sample_file": os.path.abspath(args.sample),
            "sample_fingerprint": fp_sample.to_serializable(),
            "blank_fingerprint": fp_blank.to_serializable(),
            "comparison": metrics,
            "overall_score": score,
        }, f, ensure_ascii=False, indent=2)

    pd.DataFrame(sample_corr.intensity,
                 index=[f"Ex_{x:.1f}" for x in sample_corr.ex],
                 columns=[f"{e:.2f}" for e in sample_corr.em]
                 ).to_csv(os.path.join(args.outdir,
                                       "sample_eem_corrected.csv"))

    if not args.no_plot and _HAS_MPL:
        plot_eem(sample_raw,
                 "Sample EEM (raw, after dark + aggregation)",
                 os.path.join(args.outdir, "sample_raw.png"))
        plot_eem(sample_corr,
                 "Sample EEM (corrected: blank-sub + scatter-mask + SG)",
                 os.path.join(args.outdir, "sample_corrected.png"))
        plot_eem(blank_raw,
                 "Blank EEM (raw, after dark + aggregation)",
                 os.path.join(args.outdir, "blank_raw.png"))
        plot_fri_bar(fp_sample,
                     os.path.join(args.outdir, "sample_fri_composition.png"))

    print("\n========== 比对结果 ==========")
    for k, v in metrics.items():
        print(f"  {k:<24} = {v:.4f}")
    print(f"  overall_score          = {score:.4f}")
    print(f"\n报告已写入: {os.path.abspath(args.outdir)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
